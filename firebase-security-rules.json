{
  "rules": {
    ".read": false,
    ".write": false,

    "ai-tracker": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "admins": {
      ".read": true,
      ".write": "auth != null"
    },

    "accounts": {
      ".read": true,
      ".write": "auth != null"
    },

    "logins": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "views": {
      ".read": true,
      ".write": "auth != null"
    },

    "likes": {
      ".read": true,
      ".write": "auth != null"
    },

    "admin_logs": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp"]
    },

    "config": {
      ".read": "auth != null",
      ".write": "auth != null",
      "bootstrapCodeHash": {
        ".read": true
      }
    }
  }
}
