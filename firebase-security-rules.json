{
  "rules": {
    // ── 어드민 계정 메타데이터 ──────────────────────────────────────────
    // 공개 읽기: 부트스트랩 화면에서 어드민 존재 여부 확인에 필요
    // 쓰기: Firebase Auth 인증 필수 (비밀번호는 Firebase Auth에 저장, DB에는 없음)
    "admins": {
      ".read": true,
      ".write": "auth != null"
    },

    // ── 일반 사용자 계정 메타데이터 ────────────────────────────────────
    // 읽기: 마이그레이션 기간 동안 공개 (로그인 전 SHA-256 비교에 필요)
    //       DB의 passwordHash가 모두 제거되면 "auth != null"로 되돌릴 것
    // 쓰기: 인증 필수
    "accounts": {
      ".read": true,
      ".write": "auth != null"
    },

    // ── 로그인 이력 ────────────────────────────────────────────────────
    // 읽기/쓰기 모두 인증 필수 (접속 현황은 어드민만 조회)
    "logins": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // ── 주차별 조회수 ──────────────────────────────────────────────────
    // 읽기: 공개 (조회수 표시는 누구나 볼 수 있음)
    // 쓰기: 인증 필수 (인증된 사용자만 조회수 증가 가능)
    "views": {
      ".read": true,
      ".write": "auth != null"
    },

    // ── 좋아요 카운트 ──────────────────────────────────────────────────
    // 읽기: 공개 (좋아요 수 표시는 누구나 볼 수 있음)
    // 쓰기: 인증 필수 (로그인한 사용자만 좋아요 가능)
    "likes": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}
